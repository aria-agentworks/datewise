# Supabase (PostgreSQL)
# Pooler URL for application queries (port 6543 with pgbouncer)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
# Session mode pooler for migrations (port 5432)
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres?sslmode=require"

# Clerk Authentication (https://dashboard.clerk.com > API Keys)
# IMPORTANT: Use PRODUCTION keys (not test keys) for live deployment
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Razorpay Payments (https://dashboard.razorpay.com > Settings > API Keys)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
